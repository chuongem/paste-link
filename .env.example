# PasteLink API server used by the frontend.
VITE_API_BASE_URL=https://paste-link-core.onrender.com/api/v1

# Public app URL used when generating share links in the browser.
VITE_APP_URL=http://127.0.0.1:5173

# Product name shown in browser metadata or future shared UI helpers.
VITE_APP_NAME=PasteLink

# Current upload session limit in bytes. 300MB = 300 * 1024 * 1024.
VITE_MAX_UPLOAD_SESSION_BYTES=314572800

# Swagger/OpenAPI JSON URL for developers.
VITE_OPENAPI_URL=https://paste-link-core.onrender.com/docs?api-docs.json
